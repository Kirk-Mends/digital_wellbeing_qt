    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.15);
}
*/




/* Sidebar container */
#SettingsSidebar {
    background: #f3f3f3;
    border-right: 1px solid #d0d0d0;
    padding: 10px 0;
    outline: none;
}

/* Sidebar items */
#SettingsSidebar::item {
    padding: 10px 16px;
    margin: 2px 6px;
    border-radius: 6px;
    color: #333;
    font-size: 14px;
}

/* Hover */
#SettingsSidebar::item:hover {
    background: #e5e5e5;
}

/* Selected */
#SettingsSidebar::item:selected {
    background: #0078d4;
    color: white;
}






